OPENAI_API_KEY=your_openai_api_key_here

# Cheap defaults. Increase to gpt-5.4-mini if screen understanding is too weak.
ASSISTANT_MODEL=gpt-5.4-nano
VISION_MODEL=gpt-5.4-nano
VISION_MAX_TOKENS=300
DECISION_MAX_TOKENS=500
SCREEN_MAX_WIDTH=1024
SCREEN_JPEG_QUALITY=72

OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=wav
VOICE_TTS_COOLDOWN_MS=1500
# Optional: command/path for running the OpenAI TTS CLI from the Node 16 voice process.
# OPENAI_TTS_NODE=/Users/you/.nvm/versions/node/v20.20.0/bin/node

COMPANION_HOST=127.0.0.1
COMPANION_PORT=8765
COMPANION_URL=http://127.0.0.1:8765

SCREEN_AGENT_INTERVAL=5
SCREEN_AGENT_BUFFER_SIZE=3
MEMORY_LIMIT=12
